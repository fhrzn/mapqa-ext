   "source": [
    "from staticmap3 import StaticMap, CircleMarker"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "7f22ab60",
   "metadata": {},
   "outputs": [],
   "source": [
    "m = StaticMap(640, 640)\n",
    "lat, lon = 34.07605439960424, -118.32399\n",
    "\n",
    "m.add_marker(CircleMarker((lon, lat), 'red', 12))\n",
    "image = m.render(zoom=15, center=[lon, lat])\n",
    "image.save('map.png')"
   ]
  },
